# ---- Database (Phase 1) ----
# Matches docker-compose.yml (postgres service)
DATABASE_URL="postgresql://newsqa:newsqa@localhost:55432/newsqa?schema=public"

# ---- Redis / BullMQ (Phase 3) ----
REDIS_HOST=localhost
# Host port 6380 -> Docker redis:7 (a native Windows Redis 3.0.504 service holds 6379)
REDIS_PORT=6380
# Set false to skip background ingestion on boot.
INGEST_ON_BOOT=true

# ---- OpenRouter / LLM (Phase 5) ----
# Verify :free slugs are still live at https://openrouter.ai/models (roster changes).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-...
LLM_PRIMARY_MODEL=openai/gpt-oss-120b:free
LLM_FALLBACK_MODEL=openai/gpt-oss-20b:free
# (B1) Optional per-tier models. If unset, reasoning=primary, standard/nano=fallback.
# Heavy tasks (factcheck/event/recap/chat) → reasoning; light (rewrite/suggest) → nano.
# LLM_MODEL_REASONING=openai/gpt-oss-120b:free
# LLM_MODEL_STANDARD=openai/gpt-oss-20b:free
# LLM_MODEL_NANO=mistralai/mistral-small-3.2-24b-instruct:free
APP_PUBLIC_URL=http://localhost:3000
APP_TITLE=NewsQA Bot

# ---- Embedding (Phase 2) — separate from OpenRouter ----
# Decision locked into schema: bge-m3 => vector(1024). Changing the model
# means changing vector(N) in schema.prisma AND re-embedding the whole DB.
EMBEDDING_BASE_URL=http://localhost:11434
# Dedicated Ollama (docker service ollama-ingest) for ingestion embeds.
EMBEDDING_INGEST_BASE_URL=http://localhost:11435
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
