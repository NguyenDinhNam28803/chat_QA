// NewsQA — Phase 1 schema
// pgvector extension is enabled in the first migration (see migrations/).
// Embedding dimension is LOCKED to bge-m3 = 1024. Changing the model means
// changing vector(1024) here AND re-embedding the whole DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String    @id @default(cuid())
  url         String    @unique
  title       String
  source      String
  author      String?
  publishedAt DateTime?
  content     String
  contentHash String    @unique
  topic       String?
  summary     String?
  eventId     String?
  createdAt   DateTime  @default(now())

  chunks Chunk[]
  event  Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([publishedAt])
  @@index([topic])
  @@index([eventId])
}

model Event {
  id           String    @id @default(cuid())
  title        String
  topic        String?
  summary      String? // AI consensus/conflict analysis (markdown), cached
  articleCount Int       @default(0)
  sourceCount  Int       @default(0)
  firstSeen    DateTime?
  lastSeen     DateTime?
  hotness      Float     @default(0)
  createdAt    DateTime  @default(now())

  articles Article[]

  @@index([hotness])
}

model DailyBrief {
  id        String   @id @default(cuid())
  date      String   @unique
  content   String
  createdAt DateTime @default(now())
}

// A calendar quarter of news. Data is never deleted; the homepage just shows
// the active quarter, while archived quarters live in the "Nhìn lại" review.
model Period {
  id           String   @id @default(cuid())
  kind         String   @default("quarter")
  label        String // "Quý III/2026"
  year         Int
  quarter      Int // 1-4
  startDate    DateTime
  endDate      DateTime // exclusive
  status       String   @default("active") // active | archived
  summary      String? // AI recap (markdown), cached on archive/view
  articleCount Int      @default(0)
  eventCount   Int      @default(0)
  topEvents    Json? // snapshot: top hot events of the quarter
  byTopic      Json? // snapshot: topic distribution
  createdAt    DateTime @default(now())

  @@unique([year, quarter])
  @@index([status])
}

// End-of-year synthesis across the year's quarters, cached.
model YearReview {
  id        String   @id @default(cuid())
  year      Int      @unique
  content   String
  createdAt DateTime @default(now())
}

model Chunk {
  id         String   @id @default(cuid())
  articleId  String
  ord        Int
  content    String
  tokenCount Int
  // pgvector column. Prisma has no native vector type — queried via $queryRaw.
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, ord])
  @@index([articleId])
}

model Conversation {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())

  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  citations      Json?
  feedback       Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
